{
  "$schema": "https://tr.designtokens.org/format/",
  "color": {
    "$type": "color",
    "surface": {
      "canvas": {
        "$value": "#EBE7DC",
        "$description": "Page background. Drafting paper. Warm, slightly gray, never cream."
      },
      "raised": {
        "$value": "#F4F1E8",
        "$description": "Cards, panels, raised surfaces. Vellum."
      },
      "sunken": {
        "$value": "#DDD8C9",
        "$description": "Inset areas, code blocks, quiet zones. Linen."
      }
    },
    "ink": {
      "primary": {
        "$value": "#1F1B16",
        "$description": "Primary text. Soot — warm brown-black, not charcoal, not pure black."
      },
      "secondary": {
        "$value": "#5C5448",
        "$description": "Secondary text, metadata. Driftwood."
      },
      "muted": {
        "$value": "#8A8073",
        "$description": "Tertiary, placeholders, captions. Stone."
      }
    },
    "border": {
      "default": {
        "$value": "#C7C0AE",
        "$description": "Hairlines, dividers, card borders. Twine."
      },
      "strong": {
        "$value": "#9A8F78",
        "$description": "Emphasized borders, focused inputs."
      }
    },
    "signal": {
      "primary": {
        "$value": "#3A5A40",
        "$description": "Primary action, links, brand mark. Workshop green. Single accent — use sparingly."
      },
      "primary-hover": {
        "$value": "#2F4A35",
        "$description": "Hover state for primary."
      },
      "primary-subtle": {
        "$value": "#E2E6D9",
        "$description": "Tinted background for primary-themed surfaces."
      }
    },
    "highlight": {
      "mark": {
        "$value": "#C8CC8A",
        "$description": "Inline text highlighter (<mark>). Lichen. Use sparingly for editorial emphasis."
      }
    },
    "status": {
      "success": {
        "$value": "#3A5A40",
        "$description": "Reuses signal primary. No separate green needed."
      },
      "warning": {
        "$value": "#8B6B2E",
        "$description": "Earth-toned warning, not amber, not yellow."
      },
      "danger": {
        "$value": "#7A3B2E",
        "$description": "Earth-toned error, not red-red, not terracotta-bright."
      }
    },
    "dark": {
      "$description": "Dark mode tokens — scaffold only, not implemented in v1. Values are TODO.",
      "surface": {
        "canvas": {
          "$value": "TODO",
          "$description": "Dark canvas — will be dim workshop, tea-stained paper inverted. Never violet-black."
        },
        "raised": {
          "$value": "TODO",
          "$description": "Dark raised surface."
        },
        "sunken": {
          "$value": "TODO",
          "$description": "Dark sunken surface."
        }
      },
      "ink": {
        "primary": {
          "$value": "TODO",
          "$description": "Dark primary text."
        },
        "secondary": {
          "$value": "TODO",
          "$description": "Dark secondary text."
        },
        "muted": {
          "$value": "TODO",
          "$description": "Dark muted text."
        }
      }
    }
  },
  "gradient": {
    "page": {
      "foot": {
        "$type": "gradient",
        "$value": "linear-gradient(to bottom, #EBE7DC, #DDD8C9)",
        "$description": "Vertical fade canvas→sunken. Used only at the foot of full-page sections to suggest depth. No diagonal gradients. No multi-hue gradients."
      }
    }
  },
  "space": {
    "$type": "dimension",
    "0": {
      "$value": "0px",
      "$description": "No space."
    },
    "1": {
      "$value": "4px",
      "$description": "Micro spacing."
    },
    "2": {
      "$value": "8px",
      "$description": "Compact spacing."
    },
    "3": {
      "$value": "12px",
      "$description": "Tight spacing."
    },
    "4": {
      "$value": "16px",
      "$description": "Base spacing unit."
    },
    "5": {
      "$value": "24px",
      "$description": "Comfortable spacing."
    },
    "6": {
      "$value": "32px",
      "$description": "Generous spacing."
    },
    "7": {
      "$value": "48px",
      "$description": "Section rhythm — default vertical gap between content blocks."
    },
    "8": {
      "$value": "64px",
      "$description": "Large section gap."
    },
    "9": {
      "$value": "96px",
      "$description": "Extra-large section gap."
    },
    "10": {
      "$value": "128px",
      "$description": "Maximum section gap."
    }
  },
  "radius": {
    "$type": "dimension",
    "none": {
      "$value": "0px",
      "$description": "No rounding."
    },
    "sm": {
      "$value": "4px",
      "$description": "Subtle rounding."
    },
    "md": {
      "$value": "8px",
      "$description": "Default component rounding."
    },
    "lg": {
      "$value": "12px",
      "$description": "Maximum surface rounding. No values larger than this on surfaces."
    },
    "pill": {
      "$value": "999px",
      "$description": "Used only on tags/badges. Never on cards or surfaces."
    }
  },
  "shadow": {
    "none": {
      "$type": "shadow",
      "$value": "none",
      "$description": "No shadow. Default for cards — borders do the work."
    },
    "sm": {
      "$type": "shadow",
      "$value": "0 1px 2px rgba(31, 27, 22, 0.06)",
      "$description": "Subtle elevation."
    },
    "md": {
      "$type": "shadow",
      "$value": "0 2px 8px rgba(31, 27, 22, 0.08)",
      "$description": "Moderate elevation. No shadow.lg — no glow effects, no colored shadows."
    }
  },
  "motion": {
    "duration": {
      "fast": {
        "$type": "duration",
        "$value": "120ms",
        "$description": "Quick interactions, hover color changes."
      },
      "base": {
        "$type": "duration",
        "$value": "200ms",
        "$description": "Default transitions."
      },
      "slow": {
        "$type": "duration",
        "$value": "320ms",
        "$description": "Complex transitions, overlays."
      }
    },
    "ease": {
      "standard": {
        "$type": "cubicBezier",
        "$value": [0.2, 0, 0, 1],
        "$description": "Standard easing. No bouncy springs."
      },
      "exit": {
        "$type": "cubicBezier",
        "$value": [0.4, 0, 1, 1],
        "$description": "Exit easing for elements leaving the screen."
      }
    }
  },
  "type": {
    "size": {
      "display-xl": {
        "$type": "dimension",
        "$value": "clamp(3.5rem, 5vw, 5rem)",
        "$description": "Page hero only."
      },
      "display-lg": {
        "$type": "dimension",
        "$value": "3.5rem",
        "$description": "Section openers."
      },
      "heading-xl": {
        "$type": "dimension",
        "$value": "2.25rem",
        "$description": "H1 inside content."
      },
      "heading-lg": {
        "$type": "dimension",
        "$value": "1.75rem",
        "$description": "H2."
      },
      "heading-md": {
        "$type": "dimension",
        "$value": "1.375rem",
        "$description": "H3."
      },
      "heading-sm": {
        "$type": "dimension",
        "$value": "1.125rem",
        "$description": "H4 / card titles."
      },
      "body-lg": {
        "$type": "dimension",
        "$value": "1.125rem",
        "$description": "Lede paragraphs."
      },
      "body-md": {
        "$type": "dimension",
        "$value": "1rem",
        "$description": "Default body."
      },
      "body-sm": {
        "$type": "dimension",
        "$value": "0.875rem",
        "$description": "Secondary text."
      },
      "mono-md": {
        "$type": "dimension",
        "$value": "0.9375rem",
        "$description": "Code, technical labels, eyebrow metadata."
      },
      "mono-sm": {
        "$type": "dimension",
        "$value": "0.8125rem",
        "$description": "Tags, badges, captions."
      }
    },
    "leading": {
      "display-xl": {
        "$type": "number",
        "$value": 1.02,
        "$description": "Line height for display-xl."
      },
      "display-lg": {
        "$type": "number",
        "$value": 1.05,
        "$description": "Line height for display-lg."
      },
      "heading-xl": {
        "$type": "number",
        "$value": 1.15,
        "$description": "Line height for heading-xl."
      },
      "heading-lg": {
        "$type": "number",
        "$value": 1.2,
        "$description": "Line height for heading-lg."
      },
      "heading-md": {
        "$type": "number",
        "$value": 1.3,
        "$description": "Line height for heading-md."
      },
      "heading-sm": {
        "$type": "number",
        "$value": 1.35,
        "$description": "Line height for heading-sm."
      },
      "body-lg": {
        "$type": "number",
        "$value": 1.55,
        "$description": "Line height for body-lg."
      },
      "body-md": {
        "$type": "number",
        "$value": 1.55,
        "$description": "Line height for body-md."
      },
      "body-sm": {
        "$type": "number",
        "$value": 1.5,
        "$description": "Line height for body-sm."
      },
      "mono-md": {
        "$type": "number",
        "$value": 1.5,
        "$description": "Line height for mono-md."
      },
      "mono-sm": {
        "$type": "number",
        "$value": 1.45,
        "$description": "Line height for mono-sm."
      }
    },
    "weight": {
      "regular": {
        "$type": "number",
        "$value": 400,
        "$description": "Default body weight."
      },
      "medium": {
        "$type": "number",
        "$value": 500,
        "$description": "Display, heading, and emphasis weight. Never 700+ in this system."
      }
    },
    "tracking": {
      "display": {
        "$type": "dimension",
        "$value": "-0.01em",
        "$description": "Letter-spacing for display sizes."
      },
      "body": {
        "$type": "dimension",
        "$value": "0em",
        "$description": "Letter-spacing for body text."
      },
      "mono-label": {
        "$type": "dimension",
        "$value": "0.04em",
        "$description": "Letter-spacing for uppercase mono labels (tags, badges, eyebrows)."
      }
    },
    "family": {
      "sans": {
        "$type": "fontFamily",
        "$value": ["Söhne", "General Sans", "system-ui", "sans-serif"],
        "$description": "Primary sans-serif. Söhne (paid) preferred; General Sans (Fontshare, free) as fallback. Never Inter, never Geist."
      },
      "mono": {
        "$type": "fontFamily",
        "$value": ["Berkeley Mono", "Commit Mono", "ui-monospace", "monospace"],
        "$description": "Accent mono. Berkeley Mono (paid) preferred; Commit Mono (free) as fallback. Never JetBrains Mono."
      }
    }
  },
  "layout": {
    "prose-max": {
      "$type": "dimension",
      "$value": "72ch",
      "$description": "Maximum width for prose/reading content."
    },
    "composition-max": {
      "$type": "dimension",
      "$value": "1120px",
      "$description": "Maximum width for page compositions."
    }
  }
}
